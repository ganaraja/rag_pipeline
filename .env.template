# RAG Full-Stack Application - Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# QDRANT CONFIGURATION
# ============================================================================
# Qdrant is the vector database used for storing and retrieving document embeddings

# Qdrant Mode: "embedded" for local storage or "server" for remote Qdrant
# - embedded: Runs Qdrant in-process, stores data locally (good for development)
# - server: Connects to a separate Qdrant server (required for production)
QDRANT_MODE=embedded

# Qdrant Storage Path (for embedded mode only)
# Path where Qdrant will store its data locally
QDRANT_PATH=./qdrant_db

# Qdrant Server Configuration (for server mode only)
# Host and port of your Qdrant server
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Qdrant API Key (optional, for Qdrant Cloud or secured instances)
# Leave empty if not using authentication
QDRANT_API_KEY=

# Default Collection Name
# Name of the collection where documents will be stored
QDRANT_COLLECTION=documents

# ============================================================================
# EMBEDDING MODELS CONFIGURATION
# ============================================================================
# Models used for generating embeddings from text

# Matryoshka Embedding Model
# Used for generating 64D and 768D dense embeddings
# Default: "jinaai/jina-embeddings-v3"
MATRYOSHKA_MODEL=jinaai/jina-embeddings-v3

# ColBERT Model
# Used for generating multi-vector embeddings for late interaction
# Default: "colbert-ir/colbertv2.0"
COLBERT_MODEL=colbert-ir/colbertv2.0

# SPLADE Model
# Used for generating sparse embeddings
# Default: "naver/splade-v3"
SPLADE_MODEL=naver/splade-v3

# Cross-Encoder Model (for reranking)
# Used to rerank retrieved documents
# Default: "cross-encoder/ms-marco-MiniLM-L-6-v2"
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Device for Model Inference
# Options: "cpu", "cuda", "mps" (for Apple Silicon), "auto" (auto-detect)
# Default: "cpu"
DEVICE=cpu

# ============================================================================
# LLM CONFIGURATION (Ollama)
# ============================================================================
# Configuration for the Large Language Model used for answer generation

# Ollama Base URL
# URL where Ollama server is running
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Ollama Model Name
# Name of the model to use for answer generation
# Examples: "llama3.2", "mistral", "phi3"
# Default: "llama3.2"
OLLAMA_MODEL=llama3.2

# LLM Request Timeout (seconds)
# Maximum time to wait for LLM response
# Default: 60
LLM_TIMEOUT=60

# LLM Max Retries
# Number of times to retry failed LLM requests
# Default: 3
LLM_MAX_RETRIES=3

# LLM Max Context Length (characters)
# Maximum context length to send to LLM
# Default: 4000
LLM_MAX_CONTEXT_LENGTH=4000

# ============================================================================
# CHUNKING CONFIGURATION
# ============================================================================
# Configuration for document chunking strategies

# Enable Contextual Chunking
# Add contextual information to chunks using LLM
# Default: true
ENABLE_CONTEXTUAL_CHUNKING=true

# Enable Late Chunking
# Use late chunking strategy for better embeddings
# Default: true
ENABLE_LATE_CHUNKING=true

# Semantic Chunk Size (tokens)
# Target size for semantic chunks
# Default: 512
SEMANTIC_CHUNK_SIZE=512

# ============================================================================
# RETRIEVAL CONFIGURATION
# ============================================================================
# Configuration for document retrieval pipeline

# Use Prefetch Strategy
# Enable multi-stage retrieval with prefetch
# Default: true
USE_PREFETCH=true

# Stage Limits for Prefetch
# Number of candidates at each retrieval stage
STAGE1_LIMIT=500
STAGE2_LIMIT=100
STAGE3_LIMIT=100
STAGE4_LIMIT=50

# Final Result Limit
# Maximum number of results to return to user
FINAL_LIMIT=10

# Enable Cross-Encoder Reranking
# Use cross-encoder to rerank final results
# Default: true
ENABLE_CROSS_ENCODER=true

# ============================================================================
# API CONFIGURATION
# ============================================================================
# Configuration for the FastAPI backend server

# API Host
# Host address for the API server
# Default: 0.0.0.0 (all interfaces)
API_HOST=0.0.0.0

# API Port
# Port for the API server
# Default: 8000
API_PORT=8000

# CORS Origins
# Comma-separated list of allowed origins for CORS
# Default: http://localhost:5173,http://localhost:3000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Log Level
# Logging level for the application
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Default: INFO
LOG_LEVEL=INFO

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================
# Configuration for the React frontend

# API Base URL
# URL where the backend API is running
# Default: http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# DEVELOPMENT CONFIGURATION
# ============================================================================
# Configuration for development environment

# Enable Hot Reload
# Automatically reload server on code changes
# Default: true
HOT_RELOAD=true

# Enable Debug Mode
# Show detailed error messages and stack traces
# Default: false
DEBUG_MODE=false

# ============================================================================
# PERFORMANCE CONFIGURATION
# ============================================================================
# Configuration for performance tuning

# Batch Size for Embeddings
# Number of texts to process in each embedding batch
# Default: 32
EMBEDDING_BATCH_SIZE=32

# Max Workers for Async Operations
# Number of worker threads for async operations
# Default: 4
MAX_WORKERS=4

# Request Timeout (seconds)
# Maximum time to wait for API requests
# Default: 300
REQUEST_TIMEOUT=300

# ============================================================================
# NOTES
# ============================================================================
# 
# QUICK START:
# 1. Copy this file to .env: cp .env.template .env
# 2. For local development, you can use the default values
# 3. For production, update QDRANT_MODE to "server" and configure Qdrant server
# 4. Install and start Ollama: https://ollama.ai/
# 5. Pull a model: ollama pull llama3.2
# 6. Start the backend: ./start_backend.sh
# 7. Start the frontend: ./start_frontend.sh
#
# QDRANT SETUP:
# - Embedded mode (development): No setup needed, data stored in ./qdrant_db
# - Server mode (production): Run Qdrant in Docker:
#   docker run -p 6333:6333 -p 6334:6334 -v $(pwd)/qdrant_storage:/qdrant/storage qdrant/qdrant
#
# OLLAMA SETUP:
# 1. Install Ollama from https://ollama.ai/
# 2. Start Ollama service (usually starts automatically)
# 3. Pull a model: ollama pull llama3.2
# 4. Verify it's running: curl http://localhost:11434/api/tags
#
# MODEL DOWNLOADS:
# - Models will be automatically downloaded on first use
# - This may take some time depending on your internet connection
# - Models are cached locally for subsequent uses
#
# TROUBLESHOOTING:
# - If Qdrant connection fails, ensure Qdrant server is running (server mode)
# - If Ollama connection fails, ensure Ollama service is running
# - If embedding generation is slow, consider using GPU (set DEVICE=cuda)
# - For memory issues, reduce batch sizes or use smaller models
#
