# Qdrant Configuration
# Path to Qdrant database directory (local mode)
QDRANT_PATH=./qdrant_db

# Ollama Configuration
# Base URL for Ollama API server
OLLAMA_BASE_URL=http://localhost:11434/v1

# Ollama model name to use for answer generation
# Examples: llama3.2, mistral, gpt-oss:20b
OLLAMA_MODEL=gpt-oss:20b

# Embedding Configuration
# Device for embedding model inference: cpu, cuda, mps, or auto
EMBEDDING_DEVICE=cpu

# Backend Server Configuration
# Host address to bind the server to
BACKEND_HOST=0.0.0.0

# Port to run the backend server on
BACKEND_PORT=8000
